{
  "manifest_version": 3,
  "name": "LivNet Speed Widget",
  "version": "3.0",
  "description": "Multi-Widget network monitoring extension with customizable templates, live latency tests, and diagnostic tools.",

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },

  "permissions": ["storage", "activeTab"],

  "host_permissions": ["https://api.ipify.org/", "https://www.cloudflare.com/"],

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
